# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service Role Key: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# TYPO3 Lauf-Website (server-only, nie NEXT_PUBLIC_ Prefix verwenden)
TYPO3_BASE_URL=https://www.example.de
TYPO3_LOGIN_PATH=/pfad/zur/login-seite
TYPO3_EMAIL=your-typo3-email@example.de
TYPO3_PASSWORD=your-typo3-password

# Strava-Integration (server-only)
# strava.com/settings/api → Client ID + Secret
# Authorization Callback Domain: 24-tage-lauf.vercel.app (nur Domain, kein Pfad)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# Frei wählbarer String zur Webhook-Verifizierung (z.B. ein langer zufälliger Token)
STRAVA_VERIFY_TOKEN=your-strava-verify-token

# Teams-Benachrichtigung (PROJ-19, optional)
# Microsoft Teams Incoming Webhook URL fuer Lauf-Benachrichtigungen
# Ohne diese Variable werden keine Benachrichtigungen gesendet (kein Fehler)
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Debug-Logging (PROJ-12)
# Vercel Dashboard → Settings → Environment Variables → Redeploy nach Änderung
# Werte: "debug" (erweitertes Logging) oder leer lassen (nur Fehler)
# LOG_LEVEL=debug

# E2E Tests (Playwright) — nur lokal, nie in Produktion
# Ein regulärer Supabase-Nutzer (kein Admin) für authentifizierte Tests
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=testpasswort123
# Ein Admin-Nutzer für Admin-Seiten-Tests (optional)
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=adminpasswort123
